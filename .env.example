# ===========================================
# HabeshaHub Web - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values
# cp .env.example .env.local

# Backend API URL (Required)
# For local development: http://localhost:3001/api
# For production: https://habeshahub-backend-production.up.railway.app/api
NEXT_PUBLIC_API_URL=https://habeshahub-backend-production.up.railway.app/api

# App URL (Required for auth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Optional - for Google sign-in)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Analytics (Optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
